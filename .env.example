# Port server HTTP
PORT=3000

# Secret key / token untuk akses API (dikirim di header Authorization).
# Pola seperti Fonnte: Authorization: <SECRET_KEY>. Isi string acak yang kuat.
SECRET_KEY=ganti-dengan-secret-key-yang-kuat

# URL publik server (dipakai untuk contoh integrasi di dashboard).
# Kosongkan untuk memakai host dari request (mis. http://localhost:3000)
BASE_URL=

# Password admin AWAL (seed). Hanya dipakai saat pertama kali membuat akun admin
# di database. Setelah itu, ganti password & atur 2FA lewat dashboard (panel
# Keamanan). Lupa password / hilang authenticator? Jalankan: npm run reset-admin
ADMIN_PASSWORD=ubah-password-ini

# Masa berlaku sesi login dashboard (jam)
SESSION_TTL_HOURS=8

# --- Database MariaDB ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=whatsapp_api

# Nama bot/aplikasi yang muncul di pesan (opsional)
APP_NAME=WhatsApp API

# Batas: maksimal request OTP per nomor per menit
OTP_RATE_LIMIT_PER_MINUTE=3

# Whitelist IP yang boleh akses endpoint API (/send & /send-otp).
# Pisahkan dengan koma. Mendukung IP tunggal & CIDR (mis. 192.168.1.0/24).
# KOSONGKAN untuk mengizinkan semua IP (matikan whitelist).
# Contoh: ALLOWED_IPS=127.0.0.1,::1,103.20.0.0/16
ALLOWED_IPS=

# Jumlah proxy di depan server (Nginx/Cloudflare). 0 = langsung, 1 = di balik 1 proxy.
# Diperlukan agar IP asli terbaca benar saat di belakang reverse proxy.
TRUST_PROXY=0
